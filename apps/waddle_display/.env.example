# Copy this file to `.env` or `.env.development` in the same directory (or under `assets/`).
# `.env` is gitignored — do not commit real keys.
#
# In debug builds only, entries here are merged into the process env map used by
# ProviderConfigResolver, OAuth public client id resolution, and local HTTP bind
# (see `lib/config/dev_dotenv_secrets.dart`). Release/profile builds use the
# real process environment only (e.g. systemd `Environment=`).
# Static provider API keys are read from that merged map — not from SecretStore.
#
# Google / Microsoft Graph OAuth access and refresh tokens live only in SecretStore
# (device-code sign-in or `waddlectl secrets set` on Linux). Do not put them in env vars.
#
# Display instance id (bootstrap user "display" password) is read from:
#   <applicationSupportDirectory>/waddle_instance.id
# (legacy waddle_api.key is renamed on first launch after upgrade)

# Optional operator OAuth (login routes return 501 until implemented):
# WADDLE_DISPLAY_APPLE_CLIENT_ID=

# Local REST listen IP (default 0.0.0.0 — all interfaces, for LAN/controller access).
# Set 127.0.0.1 for loopback-only. See `README.md` / `docs/pi/api.md`.
# WADDLE_DISPLAY_HTTP_BIND_IP=127.0.0.1
# WADDLE_DISPLAY_HTTP_PORT=8787

# HTTPS is on by default (self-signed cert under app support `tls/`). Set 0 to use plain HTTP.
# WADDLE_DISPLAY_HTTP_TLS=0
# WADDLE_DISPLAY_HTTP_TLS_DIR=
# WADDLE_DISPLAY_HTTP_TLS_CERT=
# WADDLE_DISPLAY_HTTP_TLS_KEY=

# Comma-separated browser origins allowed for CORS (e.g. waddle_controller on Vite :5173).
# See docs/pi/api.md and apps/waddle_controller/README.md.
# WADDLE_DISPLAY_HTTP_CORS_ORIGINS=https://127.0.0.1:5173,https://localhost:5173

# Public URL of the waddle_controller SPA (shown on controller_invite slides when screen config
# does not set controllerUrl).
# WADDLE_DISPLAY_CONTROLLER_PUBLIC_URL=https://192.168.1.10:5173

# Shared secret for POST /v1/auth/register-viewer (embedded in /join QR links). Leave unset to
# disable self-service viewer signup on this display.
# WADDLE_DISPLAY_VIEWER_REGISTRATION_SECRET=change-me

# OpenAI (joke_openai + trivia_openai + trivia_opentdb; legacy provider ids still resolve)
WADDLE_DISPLAY_OPENAI_API_KEY=sk-your-key-here

# OpenWeatherMap (weather_openweathermap)
WADDLE_DISPLAY_OPEN_WEATHER_MAP_API_KEY=your-owm-key

# Pexels (https://www.pexels.com/api/) — provider id media_pexels
WADDLE_DISPLAY_PEXELS_API_KEY=your-pexels-key

# Cap media_kit GPU texture size for Pexels video slides (width×height pixel budget).
# On Raspberry Pi / ARM Linux the app defaults to 2073600 (1920×1080) when unset.
# WADDLE_DISPLAY_PEXELS_VIDEO_MAX_TEXTURE_PIXELS=2073600

# Flickr (https://www.flickr.com/services/api/) — provider id media_flickr
WADDLE_DISPLAY_FLICKR_API_KEY=your-flickr-key

# Finnhub stock quotes (https://finnhub.io/) — provider id stock_finnhub
WADDLE_DISPLAY_FINHUB_API_KEY=your-finnhub-key

# Microsoft Graph OAuth public client id (Outlook calendar + OneDrive media) — not in SQLite.
# WADDLE_DISPLAY_MICROSOFT_GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Calendar OAuth public client id — not in SQLite.
# WADDLE_DISPLAY_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
