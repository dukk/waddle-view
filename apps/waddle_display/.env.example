# Copy this file to `.env` or `.env.development` in the same directory (or under `assets/`).
# `.env` is gitignored — do not commit real keys.
#
# In debug builds only, entries here are merged into the process env map used by
# ProviderConfigResolver (see `lib/config/dev_dotenv_secrets.dart`).
# Static provider API keys (OpenAI, Pexels, Finnhub, Flickr, weather, etc.) are read
# from that merged map — not from SecretStore.
#
# Google / Microsoft Graph OAuth access + refresh tokens can still be copied from
# this file into FlutterSecureSecretStore in debug via applyGoogleTokensFromDevDotenv /
# applyMicrosoftGraphTokensFromDevDotenv in `lib/main.dart`.
#
# Note: there is no dotenv/env var for the admin install password.
# The app reads it from the key file created at startup:
#   <applicationSupportDirectory>/waddle_api.key

# Standard name (used if WADDLE_JOKES_ACCESS_TOKEN is unset)
OPENAI_API_KEY=sk-your-key-here

# Optional: set this to use a different key for Waddle than OPENAI_API_KEY
# WADDLE_JOKES_ACCESS_TOKEN=sk-your-key-here

# Optional: trivia provider key override (falls back to OPENAI_API_KEY / jokes key)
# WADDLE_TRIVIA_ACCESS_TOKEN=sk-your-key-here

# Pexels stock photos/videos (https://www.pexels.com/api/) — PEXELS_API_KEY or WADDLE_PEXELS_ACCESS_TOKEN
# PEXELS_API_KEY=your-pexels-key
# Optional: WADDLE_PEXELS_ACCESS_TOKEN=your-pexels-key

# Flickr group pool photos (https://www.flickr.com/services/api/) — FLICKR_API_KEY or WADDLE_FLICKR_ACCESS_TOKEN
# FLICKR_API_KEY=your-flickr-key
# Optional: WADDLE_FLICKR_ACCESS_TOKEN=your-flickr-key

# Finnhub stock quotes (https://finnhub.io/) — FINNHUB_API_KEY or WADDLE_STOCKS_ACCESS_TOKEN
# FINNHUB_API_KEY=your-finnhub-key
# Optional: WADDLE_STOCKS_ACCESS_TOKEN=your-finnhub-key

# Microsoft Graph (Outlook calendar + OneDrive media) — per-account keys matching config_json "graphAccountKey"
# The same tokens are used for calendar and OneDrive sync (delegated Files.Read + Calendars.Read).
# WADDLE_MSGRAPH_ACCESS_TOKEN_personal=eyJ...
# WADDLE_MSGRAPH_REFRESH_TOKEN_personal=...

# Google Calendar — per-account keys matching config_json "googleAccountKey"
# WADDLE_GOOGLE_ACCESS_TOKEN_primary=ya29...
# WADDLE_GOOGLE_REFRESH_TOKEN_primary=1//...
