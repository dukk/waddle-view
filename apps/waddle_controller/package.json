{
  "name": "waddle_controller",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "^22.0.0 <23"
  },
  "scripts": {
    "postinstall": "npm ci --prefix ../../packages/waddle_node_tls",
    "dev": "concurrently -k -n spa,bff -c blue,magenta \"vite\" \"npm run dev:server\"",
    "dev:spa": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:check": "node tool/coverage_check.mjs --min=80 --target=90",
    "docker:build": "docker build -f Dockerfile -t waddle-controller ../..",
    "docker:run": "docker run --rm -p 8443:443 -v waddle-controller-data:/var/lib/waddle-controller waddle-controller",
    "docker:up": "npm run docker:build && npm run docker:run"
  },
  "dependencies": {
    "@waddle/node-tls": "file:../../packages/waddle_node_tls",
    "@hono/node-server": "^1.14.0",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@rjsf/core": "^5.24.0",
    "@rjsf/mui": "^5.24.0",
    "@rjsf/utils": "^5.24.0",
    "@rjsf/validator-ajv8": "^5.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@eslint/js": "^9.25.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
